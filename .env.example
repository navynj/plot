# Neon connection string (Postgres, POOLED URL recommended). Used by the app
# (Next.js loads .env) and by drizzle-kit migrate (drizzle.config.ts loads it
# via dotenv; an inline DATABASE_URL=... on the command overrides it).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth.js v5. Generate the secret with: openssl rand -base64 32
# NEVER reuse the dev secret in production.
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
